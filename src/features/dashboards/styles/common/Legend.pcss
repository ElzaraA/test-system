.dashboard-legend {
  display: flex;
  gap: 8px;

  &__vertical {
    flex-direction: column;
  }

  &__horizontal {
    flex-direction: row;
  }

  &__particle {
    & > div {
      width: 16px;
      height: 16px;
      border-radius: 50%;
    }
  }

  & > li {
    display: flex;
    gap: 8px;
    align-items: center;

    & > span {
      @include body-2;
      color: #fff;
      white-space: pre-line;
    } 
  }
}
